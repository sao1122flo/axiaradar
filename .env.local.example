# =====================================================================
# Axia — environment variables
# =====================================================================
# Copy this file to .env.local and fill in real values.
# In production, set these in Vercel → Settings → Environment Variables.
# =====================================================================

# --- Supabase (server-side only; use service_role, NOT anon) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...REPLACE...

# --- Resend (transactional email) ---
RESEND_API_KEY=re_REPLACE
RESEND_FROM_EMAIL="Axia <hello@axiaradar.com>"

# --- App secret (used as HMAC key for ip_hash, and reserved for future signed tokens) ---
# Generate with:  openssl rand -hex 32
AXIA_WAITLIST_SECRET=REPLACE_WITH_64_HEX_CHARS

# --- Optional: site URL (used by sitemap/robots/og) ---
NEXT_PUBLIC_SITE_URL=https://axiaradar.com

# --- Optional: Google Analytics 4 measurement ID ---
NEXT_PUBLIC_GA_ID=
